---
// MakerDeckBar.astro — the sub-header strip below the main header
---

<div class="makerdeck-bar">
  <div class="makerdeck-bar-inner">
    <img src="/assets/MakerDeck_Logo.svg" alt="MakerDeck" class="makerdeck-bar-logo" />
    <div class="makerdeck-bar-divider"></div>
    <div class="makerdeck-bar-items">
      <span class="makerdeck-bar-item">
        <span class="live-dot"></span>
        <a href="https://twitch.tv/makerdeck" target="_blank" rel="noopener">24/7 Stream on Twitch</a>
      </span>
      <span class="makerdeck-bar-sep hide-sm">·</span>
      <span class="makerdeck-bar-item hide-sm">
        <a href="https://youtube.com/@makerdeck" target="_blank" rel="noopener" class="yt-link">
          The Maker Show
        </a>
        — with Chris Pirillo &amp; Matt Evans · Tuesdays 6pm PST on YouTube
      </span>
    </div>
  </div>
</div>
