---
// BaseLayout.astro — wraps every page; handles <head>, header, MakerDeck bar, footer
import Header from '../components/Header.astro';
import MakerDeckBar from '../components/MakerDeckBar.astro';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  currentPage?: 'home' | 'archive';
}

const {
  title = 'MattMakes3D – Fresh Off The Bed',
  description = "A showcase of Matt Evans' latest 3D prints. Models, makes, and everything fresh off the print bed.",
  currentPage = 'home',
} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/assets/logo.svg" />
  <meta name="author" content="Matt Evans" />
  <link rel="canonical" href={`https://mattmakes3d.com${Astro.url.pathname}`} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://mattmakes3d.com/assets/og-image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://mattmakes3d.com/assets/og-image.png" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Mono:wght@400;700&family=Barlow:wght@400;500;700&display=swap" rel="stylesheet" />

  <link rel="stylesheet" href="/styles/global.css" />
  <ViewTransitions />

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "MattMakes3D",
    "url": "https://mattmakes3d.com",
    "description": description,
    "author": {
      "@type": "Person",
      "name": "Matt Evans",
      "url": "https://mattevanstech.com"
    }
  })} />

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-DYT0JD7HJM"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-DYT0JD7HJM');
  </script>
</head>
<body>
  <Header currentPage={currentPage} />
  <MakerDeckBar />

  <slot />

  <!-- ── LIGHTBOX ── -->
  <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Print details">
    <div class="lightbox-overlay"></div>
    <div class="lightbox-panel">
      <button class="lightbox-close" aria-label="Close">✕</button>
      <div class="lightbox-photo">
        <img id="lightbox-img" src="" alt="" />
      </div>
      <div class="lightbox-info">
        <div class="lightbox-eyebrow">◈ Print Details</div>
        <div class="lightbox-title" id="lightbox-title"></div>
        <div class="lightbox-meta">
          <div class="lightbox-meta-row">
            <span class="lightbox-meta-label">Printed</span>
            <span class="lightbox-meta-value" id="lightbox-date"></span>
          </div>
          <div class="lightbox-meta-row" id="lightbox-source-row">
            <span class="lightbox-meta-label">Source</span>
            <span class="lightbox-meta-value" id="lightbox-source"></span>
          </div>
        </div>
        <div class="lightbox-actions">
          <a class="lightbox-btn lightbox-btn-primary" id="lightbox-model-link" href="#" target="_blank" rel="noopener noreferrer">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M14 3h7v7h-2V6.41L10.41 15 9 13.59 17.59 5H14V3zM5 5h6V3H3v18h18v-8h-2v6H5V5z"/></svg>
            View Model
          </a>
          <button class="lightbox-btn lightbox-btn-secondary" id="lightbox-share">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92-1.31-2.92-2.92-2.92z"/></svg>
            Share
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ── LIGHTBOX SCRIPT ── -->
  <script is:inline>
    function initLightbox() {
      const lightbox = document.getElementById('lightbox');
      if (!lightbox) return;

      const overlay = lightbox.querySelector('.lightbox-overlay');
      const closeBtn = lightbox.querySelector('.lightbox-close');
      const img = document.getElementById('lightbox-img');
      const titleEl = document.getElementById('lightbox-title');
      const dateEl = document.getElementById('lightbox-date');
      const sourceEl = document.getElementById('lightbox-source');
      const sourceRow = document.getElementById('lightbox-source-row');
      const modelLink = document.getElementById('lightbox-model-link');
      const shareBtn = document.getElementById('lightbox-share');

      function openLightbox(card) {
        const id = card.dataset.id;
        const title = card.dataset.title || '';
        const photo = card.dataset.photo || '';
        const date = card.dataset.date || '';
        const modelUrl = card.dataset.modelUrl || '';
        const modelSource = card.dataset.modelSource || '';

        img.src = photo;
        img.alt = title;
        titleEl.textContent = title;

        if (date) {
          const d = new Date(date);
          dateEl.textContent = d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
        } else {
          dateEl.textContent = '—';
        }

        if (modelSource) {
          sourceEl.textContent = modelSource;
          sourceRow.style.display = '';
        } else {
          sourceRow.style.display = 'none';
        }

        if (modelUrl) {
          modelLink.href = modelUrl;
          modelLink.style.display = '';
        } else {
          modelLink.style.display = 'none';
        }

        lightbox.classList.add('is-open');
        document.body.style.overflow = 'hidden';
        history.replaceState(null, '', '#' + id);
      }

      function closeLightbox() {
        lightbox.classList.remove('is-open');
        document.body.style.overflow = '';
        history.replaceState(null, '', window.location.pathname + window.location.search);
        img.src = '';
      }

      // Event delegation for all [data-lightbox] cards
      document.addEventListener('click', function(e) {
        const card = e.target.closest('[data-lightbox]');
        if (card) openLightbox(card);
      });

      document.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') {
          const card = e.target.closest('[data-lightbox]');
          if (card) { e.preventDefault(); openLightbox(card); }
        }
        if (e.key === 'Escape') closeLightbox();
      });

      overlay && overlay.addEventListener('click', closeLightbox);
      closeBtn && closeBtn.addEventListener('click', closeLightbox);

      // Share button
      shareBtn && shareBtn.addEventListener('click', function() {
        const url = window.location.origin + window.location.pathname + window.location.hash;
        const title = titleEl.textContent;
        if (navigator.share) {
          navigator.share({ title: title + ' — MattMakes3D', url: url }).catch(() => {});
        } else {
          navigator.clipboard.writeText(url).then(() => {
            const orig = shareBtn.textContent;
            shareBtn.textContent = 'Copied!';
            setTimeout(() => { shareBtn.textContent = orig; }, 2000);
          }).catch(() => {
            prompt('Copy this link:', url);
          });
        }
      });

      // Auto-open from URL hash on page load
      const hash = window.location.hash.slice(1);
      if (hash) {
        const card = document.querySelector('[data-lightbox][data-id="' + hash + '"]');
        if (card) openLightbox(card);
      }
    }

    // Run on first load and after every ViewTransitions navigation
    document.addEventListener('astro:page-load', initLightbox);
  </script>

  <footer>
    <div class="footer-inner">
      <div class="footer-left">
        <a href="/" class="footer-logo">
          <img src="/assets/logo.svg" alt="MattMakes3D" height="40" style="width:auto;display:block;" />
          <span class="footer-logo-text">MattMakes3D</span>
        </a>
        <span class="footer-tagline">Fresh Off The Bed</span>
      </div>
      <div class="footer-right">
        <a href="/">Latest</a>
        <a href="/archive">Archive</a>
        <a href="/about">About</a>
        <a href="https://mattevanstech.com" target="_blank" rel="noopener">mattevanstech.com</a>
      </div>
    </div>
    <div class="footer-copyright">
      © {new Date().getFullYear()} MattMakes3D. All rights reserved.
    </div>
  </footer>
</body>
</html>
