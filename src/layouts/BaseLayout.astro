---
// BaseLayout.astro — wraps every page; handles <head>, header, MakerDeck bar, footer
import Header from '../components/Header.astro';
import MakerDeckBar from '../components/MakerDeckBar.astro';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  currentPage?: 'home' | 'archive';
}

const {
  title = 'MattMakes3D – Fresh Off The Bed',
  description = "A showcase of Matt Evans' latest 3D prints. Models, makes, and everything fresh off the print bed.",
  currentPage = 'home',
} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/assets/logo.svg" />
  <meta name="author" content="Matt Evans" />
  <link rel="canonical" href={`https://mattmakes3d.com${Astro.url.pathname}`} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://mattmakes3d.com/assets/og-image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://mattmakes3d.com/assets/og-image.png" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Mono:wght@400;700&family=Barlow:wght@400;500;700&display=swap" rel="stylesheet" />

  <link rel="stylesheet" href="/styles/global.css" />
  <ViewTransitions />

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "MattMakes3D",
    "url": "https://mattmakes3d.com",
    "description": description,
    "author": {
      "@type": "Person",
      "name": "Matt Evans",
      "url": "https://mattevanstech.com"
    }
  })} />

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-DYT0JD7HJM"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-DYT0JD7HJM');
  </script>
</head>
<body>
  <Header currentPage={currentPage} />
  <MakerDeckBar />

  <slot />

  <footer>
    <div class="footer-inner">
      <div class="footer-left">
        <strong>MattMakes3D</strong> · Fresh Off The Bed
      </div>
      <div class="footer-right">
        <a href="https://mattevanstech.com" target="_blank" rel="noopener">mattevanstech.com</a>
        <a href="https://makerworld.com" target="_blank" rel="noopener">MakerWorld</a>
      </div>
    </div>
  </footer>
</body>
</html>
