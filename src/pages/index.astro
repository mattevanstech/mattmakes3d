---
// index.astro — home page: featured print + grid + queue sidebar
import BaseLayout from '../layouts/BaseLayout.astro';
import PrintCard from '../components/PrintCard.astro';
import QueuePanel from '../components/QueuePanel.astro';
import type { Print, QueueItem } from '../content/types';

// ── Data ─────────────────────────────────────────────────────────────────────
import { getPrints, getQueue } from '../lib/notion';

const prints = await getPrints();
const queue = await getQueue();
const queuePreview = queue.slice(0, 5);

// Sort newest first
const sorted = [...prints].sort((a, b) => b.date.localeCompare(a.date));

// Pick up to 2 featured items; backfill with newest if needed
const markedFeatured = sorted.filter(p => p.featured);
const backfill = sorted.filter(p => !p.featured);
const featuredItems = [...markedFeatured, ...backfill].slice(0, 2);
const grid = sorted.filter(p => !featuredItems.includes(p));
---

<BaseLayout currentPage="home">

  <!-- ── HERO BAND ─────────────────────────────────────────────────────── -->
  <div class="hero-band">
    <div class="hero-band-inner">
      <div class="hero fade-up fade-up-1">
        <div class="hero-eyebrow">Print Log</div>
        <h1>Fresh Off<em>The Bed.</em></h1>
        <p class="hero-sub">
          A running record of what's coming off the printer. Models, makes,
          and everything in between.
        </p>
      </div>
      <QueuePanel items={queuePreview} totalCount={queue.length} />
    </div>
  </div>

  <!-- ── MAIN ──────────────────────────────────────────────────────────── -->
  <main>

    <!-- Featured -->
    <div id="featured-container" class="fade-up fade-up-2">
      <div class="section-heading">
        <span class="section-heading-eyebrow">◈ Top Picks</span>
        <h2 class="section-heading-title">Featured Makes</h2>
      </div>
      <div class="featured-grid">
        {featuredItems.map((item) => {
          const itemDate = new Date(item.date).toLocaleDateString('en-US', {
            year: 'numeric', month: 'long', day: 'numeric',
          });
          return (
            <div class="featured-card">
              <div class="featured-photo">
                {item.photo
                  ? <img src={item.photo} alt={item.title} />
                  : <div class="photo-placeholder"><span>NO PHOTO</span></div>
                }
                <div class="featured-badge">Featured</div>
              </div>
              <div class="featured-info">
                <div>
                  <div class="featured-title">{item.title}</div>
                  <div class="featured-date"><span>◈</span>{itemDate}</div>
                  <div class="ruler">
                    {Array.from({ length: 24 }).map((_, i) => (
                      <div class="ruler-tick" style={`height: ${i % 5 === 4 ? 14 : 8}px`}></div>
                    ))}
                  </div>
                </div>
                {item.model_url && (
                  <a href={item.model_url} class="model-link" target="_blank" rel="noopener noreferrer">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M14 3h7v7h-2V6.41L10.41 15 9 13.59 17.59 5H14V3zM5 5h6V3H3v18h18v-8h-2v6H5V5z"/>
                    </svg>
                    View on {item.model_source}
                  </a>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Grid -->
    <div class="fade-up fade-up-3">
      <div class="section-heading">
        <span class="section-heading-eyebrow">◈ The Collection</span>
        <h2 class="section-heading-title">All Makes <span class="section-heading-count">{grid.length}</span></h2>
      </div>
      <div id="prints-grid">
        {grid.map(print => <PrintCard print={print} />)}
      </div>
    </div>

  </main>
</BaseLayout>
